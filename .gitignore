# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
venv/
env/
.venv/
ENV/

# Logs (runtime, regenerated)
logs/*.log
*.log
logs/decisions_*.jsonl

# Runtime backtest receipts (regenerated by every backtest/validate run).
# The JSON summary report stays tracked; the per-run CSV/HTML receipts do not.
backtests/trades_*.csv
backtests/equity_*.csv
backtests/report_*.html
backtests/composite_*.json

# IDE
.idea/
.vscode/
*.swp
.DS_Store

# Trained model artifacts (rebuilt locally by `python main.py --mode train`).
# These are environment-specific pickles: a model saved on a NumPy 2.x machine
# CANNOT be unpickled on the Windows 7 / NumPy 1.x live box (raises
# "No module named 'numpy._core'"). Never commit them; train on the target box.
models/*.pkl
models/*.h5
models/*.joblib
models/*.incompatible
!models/.gitkeep
